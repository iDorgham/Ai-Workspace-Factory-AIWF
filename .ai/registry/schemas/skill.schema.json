{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SkillDefinition",
  "type": "object",
  "required": ["id", "path", "source", "version", "status"],
  "properties": {
    "id": { "type": "string" },
    "path": { "type": "string" },
    "source": { "type": "string", "enum": ["workspace", "external", "plugin"] },
    "version": { "type": "string" },
    "status": { "type": "string", "enum": ["active", "planned", "deprecated"] },
    "mapped_commands": {
      "type": "array",
      "items": { "type": "string" }
    },
    "compatible_agents": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_tools": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
