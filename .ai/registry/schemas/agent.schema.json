{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AgentDefinition",
  "type": "object",
  "required": [
    "id",
    "tier",
    "role",
    "single_responsibility",
    "owns",
    "triggers",
    "subagents",
    "input_contract",
    "output_contract",
    "validation_gates",
    "error_handling"
  ],
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "tier": { "type": "integer", "minimum": 1, "maximum": 3 },
    "role": { "type": "string" },
    "single_responsibility": { "type": "string" },
    "owns": { "type": "array", "items": { "type": "string" } },
    "triggers": { "type": "array", "items": { "type": "string" } },
    "subagents": { "type": "array", "items": { "type": "string" } },
    "input_contract": { "type": "array", "items": { "type": "string" } },
    "output_contract": { "type": "array", "items": { "type": "string" } },
    "validation_gates": { "type": "array", "items": { "type": "string" } },
    "error_handling": { "type": "array", "items": { "type": "string" } },
    "notes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
