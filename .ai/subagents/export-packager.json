{
  "id": "export-packager",
  "parent_agent": "workflow-agent",
  "trigger": "/export",
  "single_responsibility": "Package approved content into CSV and CMS ZIP",
  "input": {
    "required": {
      "approved_content": "array<{file_path, markdown, metadata}> \u2014 status must be 'approved'",
      "csv_schema": "object \u2014 from .ai/templates/csv-schemas/content-export.json"
    }
  },
  "output": {
    "csv_export": "string \u2014 path to content/sovereign/outputs/csv-exports/[slug].csv",
    "cms_pack": "string \u2014 path to content/sovereign/outputs/cms-packs/[slug].zip"
  },
  "validation": {
    "block_if_status_not_approved": true,
    "csv_schema_match_required": "100%",
    "version_output_if_already_exists": true
  },
  "writes": [
    "content/sovereign/outputs/csv-exports/",
    "content/sovereign/outputs/cms-packs/"
  ],
  "error_owner": "export-packager",
  "escalates_to": "workflow-agent"
}
