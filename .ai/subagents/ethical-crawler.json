{
  "id": "ethical-crawler",
  "parent_agent": "scraper-agent",
  "trigger": "/scrape *, /sync (after delta-detector)",
  "single_responsibility": "Fetch URLs ethically \u2014 robots.txt compliance, rate limiting, PII filtering",
  "input": {
    "required": {
      "delta_payload": "object<slug, {new_urls, updated_urls}> \u2014 from delta-detector",
      "robots_txt_per_domain": "object<domain, rules>"
    }
  },
  "output": {
    "raw_pages": "array<{url: string, html: string, status_code: int, fetched_at: ISO8601}>",
    "compliance_log": "array<{url, robots_allowed: bool, skipped_reason?: string}>"
  },
  "validation": {
    "robots_txt_compliance": "100% \u2014 never bypass",
    "minimum_delay_between_requests_seconds": 2,
    "retry_on_429": [
      5,
      10,
      20
    ],
    "max_retries_per_url": 3,
    "pii_patterns_filtered": [
      "email",
      "phone",
      "full_name",
      "address"
    ],
    "block_if_robots_disallows": true
  },
  "writes": [
    ".ai/logs/scrape-audit.jsonl (append only)"
  ],
  "error_owner": "ethical-crawler",
  "escalates_to": "scraper-agent"
}
