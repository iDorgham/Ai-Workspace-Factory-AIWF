  Rel(cms_core, media, "Stores asset refs", "API")
  Rel(ui, media, "Loads images", "HTTPS")
  Rel(ui, edge, "Served via", "HTTPS")
  Rel(git, ui, "Builds deploy", "CI/CD")
  Rel(plan_store, cms_core, "Informs content model (human process)", "manual")

  UpdateLayoutConfig($c4ShapeInRow="3", $c4BoundaryInRow="1")

