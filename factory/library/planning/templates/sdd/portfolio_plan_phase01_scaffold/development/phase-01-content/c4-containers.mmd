C4Container
  title Container architecture — portfolio website (draft)

  Person(visitor, "Site visitor", "Reads public pages")
  Person(editor, "Content editor", "Uses CMS UI")

  System_Boundary(portfolio, "Portfolio system") {

    Container(ui, "Public web app", "TBD e.g. Next.js", "SSR/SSG pages, i18n, SEO")
