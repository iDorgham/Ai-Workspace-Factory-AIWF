    Container(media, "Media / assets", "TBD CDN", "Images, transforms, caching")

    Container(plan_store, "Plan store", "Markdown + JSON", "This .ai/plan folder + traceability")
  }

  System_Ext(git, "GitHub", "Repo + Actions")
  System_Ext(edge, "Edge / CDN", "Cache + TLS termination")

