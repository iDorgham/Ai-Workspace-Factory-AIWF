{
  "id": "rule-updater",
  "parent_agent": "brand-agent",
  "trigger": "/refine brand voice (after drift-detector)",
  "single_responsibility": "Merge new patterns into style-rules.md, resolve conflicts",
  "input": {
    "required": {
      "drift_report": "object \u2014 from drift-detector",
      "existing_style_rules": "string"
    }
  },
  "output": {
    "updated_style_rules": "string \u2014 Markdown with new/updated rules",
    "conflict_report": "array<{rule_a, rule_b, conflict_description}>"
  },
  "validation": {
    "no_rule_conflicts_in_output": true,
    "test_new_rules_against_minimum_samples": 3,
    "never_delete_rules": true,
    "deprecate_with_tag_instead": "[DEPRECATED]"
  },
  "writes": [
    "content/sovereign/reference/brand-voice/style-rules.md",
    "content/sovereign/reference/brand-voice/glossary.md"
  ],
  "error_owner": "rule-updater",
  "escalates_to": "brand-agent",
  "description": "Specialized subagent for rule updater tasks within the department field context."
}