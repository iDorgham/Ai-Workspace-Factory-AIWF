{
  "template_id": "content-discovery-interview",
  "version": "1.0.0",
  "title": "Website Content Discovery Session",
  "description": "A structured discovery interview to define the full content strategy before any creation begins. Completed answers are fed to the Content Planner Agent to generate phase-based task plans.",
  "sections": [
    {
      "id": "S1",
      "title": "Home Page Style",
      "questions": [
        {
          "id": "Q1.1",
          "prompt": "What visual style do you want for your home page?",
          "type": "single-choice",
          "options": [
            "Dark Industrial (high-tech, dark background, neon accents)",
            "Clean Corporate (white, minimal, trust-focused)",
            "Bold Startup (vivid gradients, large type, dynamic)",
            "Premium MENA (Arabic calligraphy influence, gold accents)",
            "Custom (describe below)"
          ],
          "allow_custom": true
        },
        {
          "id": "Q1.2",
          "prompt": "What is the primary goal of your home page?",
          "type": "single-choice",
          "options": [
            "Lead generation (capture emails/contacts)",
            "Product showcase (explain features in depth)",
            "Brand credibility (build trust and authority)",
            "Direct sales (e-commerce, buy now flow)",
            "Hybrid (combine multiple goals)"
          ]
        },
        {
          "id": "Q1.3",
          "prompt": "What sections must appear on the home page? (select all that apply)",
          "type": "multi-choice",
          "options": [
            "Hero / Banner",
            "Stats / Social Proof",
            "Core Features / Pillars",
            "How It Works",
            "Pricing Table",
            "Testimonials",
            "Case Studies",
            "FAQ",
            "Contact Form",
            "Newsletter Signup",
            "Video Section",
            "Map / Regional Coverage"
          ]
        }
      ]
    },
    {
      "id": "S2",
      "title": "Navigation & Menu",
      "questions": [
        {
          "id": "Q2.1",
          "prompt": "What type of main navigation do you want?",
          "type": "single-choice",
          "options": [
            "Simple horizontal navbar (5-7 links)",
            "Mega-menu (dropdowns with icons and descriptions)",
            "Sidebar navigation (always visible)",
            "Minimal (logo + 3 links + CTA button)"
          ]
        },
        {
          "id": "Q2.2",
          "prompt": "Should the header be sticky (stays at the top when scrolling)?",
          "type": "boolean"
        },
        {
          "id": "Q2.3",
          "prompt": "Do you need a mobile hamburger menu?",
          "type": "boolean"
        }
      ]
    },
    {
      "id": "S3",
      "title": "Pages to Build",
      "questions": [
        {
          "id": "Q3.1",
          "prompt": "Which pages do you need? (select all that apply)",
          "type": "multi-choice",
          "options": [
            "Home",
            "About Us",
            "Services / Products",
            "Pricing",
            "Blog / Insights",
            "Case Studies",
            "Contact",
            "FAQ",
            "Careers",
            "Partner Program",
            "Documentation / Docs",
            "Login / Dashboard Entry",
            "Custom landing pages per campaign"
          ],
          "allow_custom": true
        },
        {
          "id": "Q3.2",
          "prompt": "Do you need legal pages?",
          "type": "multi-choice",
          "options": [
            "Privacy Policy",
            "Terms of Service",
            "Data Residency Protocol",
            "Cookie Policy",
            "Compliance Certification",
            "Refund Policy"
          ]
        }
      ]
    },
    {
      "id": "S4",
      "title": "Language & Locale",
      "questions": [
        {
          "id": "Q4.1",
          "prompt": "Which languages do you need content in?",
          "type": "multi-choice",
          "options": [
            "English (Global)",
            "Arabic — Egyptian (AR-EG)",
            "Arabic — Gulf (AR-SA / AR-AE)",
            "French",
            "Other (specify)"
          ],
          "allow_custom": true
        },
        {
          "id": "Q4.2",
          "prompt": "Should Arabic content use Egyptian dialect and formal business tone?",
          "type": "boolean"
        },
        {
          "id": "Q4.3",
          "prompt": "Do you need RTL layout support for Arabic pages?",
          "type": "boolean"
        }
      ]
    },
    {
      "id": "S5",
      "title": "SEO Strategy",
      "questions": [
        {
          "id": "Q5.1",
          "prompt": "Do you want an SEO research phase before content creation starts?",
          "type": "boolean"
        },
        {
          "id": "Q5.2",
          "prompt": "Do you have existing keywords you want to rank for?",
          "type": "text",
          "placeholder": "e.g. AI SaaS Egypt, Law 151 compliance platform..."
        },
        {
          "id": "Q5.3",
          "prompt": "Who are your 1-3 main competitors? (URLs or names)",
          "type": "text",
          "placeholder": "e.g. competitor1.com, competitor2.io"
        },
        {
          "id": "Q5.4",
          "prompt": "What is your primary target market?",
          "type": "single-choice",
          "options": [
            "Egypt / MENA region (Arabic-speaking)",
            "Gulf states (KSA, UAE, Qatar)",
            "Global English-speaking market",
            "Multi-market (all of the above)"
          ]
        }
      ]
    },
    {
      "id": "S6",
      "title": "Components & Interactive Elements",
      "questions": [
        {
          "id": "Q6.1",
          "prompt": "Which interactive elements do you need?",
          "type": "multi-choice",
          "options": [
            "Contact / Sales form",
            "Newsletter signup form",
            "Pricing calculator",
            "Exit-intent popup",
            "Cookie consent banner",
            "Live chat widget",
            "Compliance alert popup",
            "Residency verification form",
            "Demo booking widget"
          ]
        },
        {
          "id": "Q6.2",
          "prompt": "Do you need CTAs (calls-to-action) on every page?",
          "type": "boolean"
        }
      ]
    }
  ],
  "output": "plan/{workspace}/content-plan.md"
}
