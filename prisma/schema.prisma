// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Shard {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  vertical    String   // LEGAL, MEDICAL, FINANCE, etc.
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]
  sessions    AgentSession[]
  content     Content[]
}

model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  role        String   @default("USER") // ADMIN, EDITOR, USER
  shardId     String
  shard       Shard    @relation(fields: [shardId], references: [id])
  createdAt   DateTime @default(now())
}

model AgentSession {
  id          String    @id @default(cuid())
  shardId     String
  shard       Shard     @relation(fields: [shardId], references: [id])
  messages    Message[]
  createdAt   DateTime  @default(now())
}

model Message {
  id          String       @id @default(cuid())
  role        String       // USER, AI, SYSTEM
  content     String
  sessionId   String
  session     AgentSession @relation(fields: [sessionId], references: [id])
  createdAt   DateTime     @default(now())
}

model Content {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  body        String   // MDX content
  shardId     String
  shard       Shard    @relation(fields: [shardId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  entity      String
  entityId    String
  actor       String
  metadata    Json?
  timestamp   DateTime @default(now())
}
