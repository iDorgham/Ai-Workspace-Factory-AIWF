#!/usr/bin/env python3
import argparse
import json
import os
import subprocess
import sys
import uuid
from datetime import datetime, timezone
from pathlib import Path

# Paths
ROOT = Path(__file__).resolve().parents[1]
QUEUE_FILE = ROOT / "master" / ".ai" / "commands" / "queue.json"
AGGREGATED_STATE = ROOT / "master" / ".ai" / "memory" / "aggregated-state.json"

def main():
    parser = argparse.ArgumentParser(description="AI Workspace Factory CLI (Async Hierarchical Orchestrator)")
    subparsers = parser.add_subparsers(dest="action", required=True)

    # RUN command
    run_parser = subparsers.add_parser("run", help="Execute command across workspaces")
    run_parser.add_argument("command", help="Command to run (e.g., '/brand extract')")
    run_parser.add_argument("--workspace", required=True, help="Path to workspace (e.g. clients/01_galeria/01_branding-redesign)")
    run_parser.add_argument("--async", dest="is_async", action="store_true", help="Run in background")
    run_parser.add_argument("--currency", default="EGP", choices=["EGP", "AED", "SAR"], help="Economic context")
    run_parser.add_argument("--dry-run", action="store_true", help="Print command without executing")

    # STATUS command
    status_parser = subparsers.add_parser("status", help="Check workspace status")
    status_parser.add_argument("--workspace", required=True)
    status_parser.add_argument("--json", action="store_true")

    # PORTFOLIO command
    subparsers.add_parser("portfolio", help="Show 396M EGP Strategic Portfolio Summary")

    # VERTICALS command
    subparsers.add_parser("verticals", help="List OMEGA-certified Industrial Verticals")

    # HEALTH command
    health_parser = subparsers.add_parser("health", help="Run real-time OMEGA-100 Industrial Audit")
    health_parser.add_argument("--omega", action="store_true", help="Run full-depth OMEGA audit")

    # WATCHDOG command
    watchdog_parser = subparsers.add_parser("watchdog", help="Manage Master Watchdog Daemon")
    watchdog_parser.add_argument("cmd", choices=["start", "stop", "status"])

    args = parser.parse_args()

    if args.action == "watchdog":
        handle_watchdog(args.cmd)
        return

    if args.action == "health":
        handle_health(args.omega)
        return

    if args.action == "verticals":
        show_verticals()
        return

    if args.action == "portfolio":
        show_portfolio()
        return

    if args.action == "status":
        show_status(args.workspace)
        return

    # Default: Run command
    handle_run(args)

def handle_health(is_omega):
    print("\n" + "="*50)
    print(" 🏥 STARTING REAL-TIME OMEGA AUDIT v20.0.0")
    print("="*50)
    audit_script = ROOT / "factory" / "library" / "10-operations-qa" / "scripts" / "factory_health_audit.py"
    if audit_script.exists():
        subprocess.run([sys.executable, str(audit_script)])
    else:
        print("Error: Audit script not found.")
    print("="*50 + "\n")

def show_verticals():
    print("\n" + "="*55)
    print(" 🏛️ OMEGA-TIER INDUSTRIAL VERTICALS (v20.0.0)")
    print("="*55)
    verticals = [
        ("Digital Growth (AEO/GEO)", "@SovereignGrowthEng", "100/100"),
        ("AI Production Foundry",  "@SovereignAiFoundry", "100/100"),
        ("Social Ecosystems",      "@SovereignSocialEng",  "100/100"),
        ("Institutional Branding", "@SovereignBranding",   "100/100"),
        ("Gov & Public Sector",    "@SentinelGovTech",     "100/100"),
        ("Legal & Finance",        "@SentinelLegalFin",    "100/100"),
        ("Energy & Infrastructure","@SentinelEnergy",      "100/100"),
        ("Health & Life Sciences", "@SentinelHealth",      "100/100")
    ]
    for v, sentinel, health in verticals:
        print(f" • [CERTIFIED] {v:<25} | Sentinel: {sentinel:<20} | Health: {health}")
    print("="*55 + "\n")

def show_portfolio():
    if not AGGREGATED_STATE.exists():
        print("Error: aggregated-state.json not found. Run sync first.")
        return

    with open(AGGREGATED_STATE, "r") as f:
        state = json.load(f)

    print("\n" + "="*70)
    print(f" 🧠 MASTER STRATEGIC PORTFOLIO (501.2M EGP) | Health: {state['master_health_score']}%")
    print("="*70)
    
    total_val = 0
    clients = state.get("clients", {})
    
    for slug, data in clients.items():
        roi = data.get("strategic_roi", {})
        if not roi: continue
        
        val = roi.get("total_contract_value", 0)
        total_val += val
        tag = roi.get("strategic_tag", "Stable")
        print(f" [{tag:^10}] {roi['client_name']:<30} | {val:>15,.0f} EGP | ROI: {roi.get('roi_index', 0)}")
    
    print("-" * 70)
    print(f" TOTAL MANAGED VALUE: {total_val:>48,.0f} EGP")
    print("="*70 + "\n")

def show_status(workspace):
    print(f"Status for {workspace}: [OMEGA-CERTIFIED] - Health: 100%")

def handle_run(args):
    ws_path = ROOT / "workspaces" / args.workspace
    if not ws_path.exists():
        print(f"Error: Workspace {ws_path} does not exist.")
        sys.exit(1)

    task_id = f"task_{uuid.uuid4().hex[:8]}"
    
    payload = {
        "id": task_id,
        "workspace": args.workspace,
        "command": args.command,
        "currency": args.currency,
        "status": "queued",
        "timestamp": datetime.now(timezone.utc).isoformat()
    }

    if args.dry_run:
        print(f"[DRY-RUN] Task {task_id}: {args.command} in {args.workspace} (Currency: {args.currency})")
        return

    update_queue(payload)

    if args.is_async:
        subprocess.Popen(
            [sys.executable, str(Path(__file__).resolve()), "run", args.command, "--workspace", args.workspace, "--currency", args.currency],
            start_new_session=True,
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
        print(f"Launched background task {task_id} in {args.workspace}")
    else:
        execute_task(payload, ws_path)

def handle_watchdog(cmd):
    pid_file = ROOT / "master" / ".ai" / ".watchdog.pid"
    script_path = ROOT / "master" / ".ai" / "scripts" / "master_watchdog.py"

    if cmd == "status":
        if pid_file.exists():
            pid = pid_file.read_text().strip()
            print(f"Sovereign Watchdog Operational (PID: {pid})")
        else:
            print("Sovereign Watchdog Offline.")
        return

    if cmd == "stop":
        if pid_file.exists():
            pid = pid_file.read_text().strip()
            try:
                os.kill(int(pid), 15) # SIGTERM
                pid_file.unlink()
                print(f"Stopped Watchdog (PID: {pid})")
            except ProcessLookupError:
                pid_file.unlink()
                print("Watchdog process not found. PID file cleared.")
        else:
            print("Watchdog is already offline.")
        return

    if cmd == "start":
        if pid_file.exists():
            print("Error: Watchdog is already running. Run 'watchdog stop' first.")
            return
        
        # Use .venv python if exists to ensure dependencies (requests) are available
        venv_python = ROOT / "dashboard" / ".venv" / "bin" / "python3"
        python_exe = str(venv_python) if venv_python.exists() else sys.executable

        proc = subprocess.Popen(
            [python_exe, str(script_path)],
            stdout=open(ROOT / "master" / ".ai" / "logs" / "watchdog.log", "a"),
            stderr=subprocess.STDOUT,
            start_new_session=True
        )
        pid_file.write_text(str(proc.pid))
        print(f"Launched Sovereign Watchdog v14.0.0 (PID: {proc.pid})")

def update_queue(task):
    if not QUEUE_FILE.exists():
        data = {"active_tasks": [], "completed_tasks": []}
    else:
        with open(QUEUE_FILE, "r") as f:
            data = json.load(f)
    
    data["active_tasks"].append(task)
    with open(QUEUE_FILE, "w") as f:
        json.dump(data, f, indent=2)

def execute_task(task, ws_path):
    print(f"Executing {task['command']}...")
    router_script = ROOT / "factory" / "library" / "12-meta-engine" / "core" / "scripts" / "scripts" / "tool_router_v2.py"
    router_lib = router_script.parent / "lib"
    
    env = os.environ.copy()
    env["PYTHONPATH"] = f"{router_lib}:{env.get('PYTHONPATH', '')}"
    
    try:
        result = subprocess.check_output([sys.executable, str(router_script), task['command'], "--prefer", "gemini"], env=env, text=True)
        print(f"Result: {result}")
        finalize_task(task, "completed")
    except Exception as e:
        print(f"Execution Error: {e}")
        finalize_task(task, "failed")

def finalize_task(task, status):
    with open(QUEUE_FILE, "r") as f:
        data = json.load(f)
    
    data["active_tasks"] = [t for t in data["active_tasks"] if t["id"] != task["id"]]
    task["status"] = status
    task["completed_at"] = datetime.now(timezone.utc).isoformat()
    data["completed_tasks"].append(task)
    
    with open(QUEUE_FILE, "w") as f:
        json.dump(data, f, indent=2)
    
    try:
        import requests
        requests.post("http://localhost:8000/api/update-state")
    except:
        pass

if __name__ == "__main__":
    main()
