# IDE & System
.DS_Store
**/__pycache__/
*.py[cod]
.venv/

# AI Tool Metadata (Keep IDE-specific metadata local)
.antigravity/
.claude/
# Entire .cursor/ is local (commands/rules may be synced by tooling but do not
# force-add hook state e.g. hooks/state/continual-learning-index.json — never commit .cursor/).
.cursor/
# Rules mirror only: `sync_ide_triple_layer.sh` rsyncs `.cursor/rules/` → here for agents/CLI.
# Canonical editor rules stay under `.cursor/rules/`; do not version this copy.
.ai/rules/
.kilocode/
.kiro/
.qwen/

# Factory Outputs & Backups (Local only)
.backup/
# Workspaces: track only root + tier governance files; slug trees & templates stay local.
workspaces/*
!workspaces/README.md
!workspaces/.gitkeep
!workspaces/personal/
workspaces/personal/*
!workspaces/personal/README.md
!workspaces/personal/metadata.json
!workspaces/clients/
workspaces/clients/*
!workspaces/clients/README.md

# AIWF Intelligence Layer (MUST BE TRACKED)
# We remove .ai/ from the ignore list
.ruff_cache
